{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MemorySettings": {
    "DefaultThresholdMB": 512,
    "MaxAllowedThresholdMB": 2048,
    "CleanupIntervalSeconds": 30,
    "MaxAllocationSizeMB": 256,
    "MaxConcurrentAllocations": 10,
    "EnableResourceLimiting": true
  }
}
