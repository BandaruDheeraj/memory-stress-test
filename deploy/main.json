            }
          ]
        }
      },
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "condition": "[parameters('enableApplicationInsights')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[variables('webAppName')]",
      "location": "[resourceGroup().location]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "siteConfig": {
          "netFrameworkVersion": "v8.0",
          "alwaysOn": "[if(and(and(not(equals(parameters('appServicePlanSku'), 'B1')), not(equals(parameters('appServicePlanSku'), 'B2'))), not(equals(parameters('appServicePlanSku'), 'B3'))), true(), false())]",
          "healthCheckPath": "/api/memory/status",
          "appSettings": [
